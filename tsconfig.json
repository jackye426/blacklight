{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "apps/*/src/**/*.ts",
    "packages/*/src/**/*.ts",
    "adapters/*/src/**/*.ts"
  ],
  "exclude": ["**/node_modules", "**/dist", "vendor"]
}
